
<article class="pad-1 bg-lighter radius">
  <div class="grid-col2-thumb">
    <header>
      <h3>{{ edu.data.degree }}</h3>
      <h4>{{ edu.data.title }}</h4>
      <h4>
        <svg
          viewBox="0 0 24 24"
          class="icon"
          role="img"
          aria-hidden="true"
          focusable="false"
        >
          <use xlink:href="images/defs.svg#marker"></use>
        </svg>
        {{ edu.data.location }}
      </h4>
      <h4>
        <svg
          viewBox="0 0 24 24"
          class="icon"
          role="img"
          aria-hidden="true"
          focusable="false"
        >
          <use xlink:href="images/defs.svg#calendar"></use>
        </svg>
        Class of <time datetime="{{ edu.data.dateTo }}">{{ edu.data.dateTo | readableDate }}</time>
      </h4>
    </header>
    <img
      src="{{ edu.data.image }}"
      alt="{{ edu.data.title}}"
      loading="lazy"
      class="radius thumbnail"
    />
  </div>

  {# <p>
    {{ edu.data.content | safe }}
  </p> #}
  
</article>