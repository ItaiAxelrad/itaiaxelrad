---
layout: layouts/base.njk
---
<main id="main">
<a href="/projects">&larr; Back to porjects</a>
<article id="{{ title | slug }}" class="project">

  <header class="article-header">
    <time class="dt-published">{{ date | fullDate }}</time>
    <h1>{{ title }}</h1>
  </header>

  {{ content | safe }}

</article>

</main>

<nav class="projectNav">

  <div class="previous">
    {%- set previousProject = collections.projects | getPreviousCollectionItem(page) -%}
    {%- if previousProject -%}
    <small>Previous Project:</small><br>
    <a href="{{ previousProject.url }}">{{ previousProject.data.title }}</a>
    {%- else -%}
    {%- endif -%}
  </div>

  <div class="next">
    {%- set nextProject = collections.projects | getNextCollectionItem(page) -%}
    {%- if nextProject -%}
    <small>Next Project:</small><br>
    <a href="{{ nextProject.url }}">{{ nextProject.data.title }}</a>
    {%- else -%} 
    {%- endif -%}
  </div>

</nav>
