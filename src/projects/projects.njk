---
title: Projects
layout: layouts/base.njk
permalink: /projects/index.html
eleventyExcludeFromCollections: true
---

<h1>{{ title }}</h1>

<ul>
{% for project in collections.projects %}
  <li>
    <a href="{{ project.url | url }}">{{ project.data.title }}</a>
    {{ project.content | safe }}
  </li>
{% endfor %}
</ul>